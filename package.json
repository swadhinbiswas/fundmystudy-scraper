{
  "name": "fundmystudy-bot",
  "version": "1.0.0",
  "description": "Scrapes scholarship + PhD opportunities from public sources and writes directly to the FundMyStudy Turso database. Runs on GitHub Actions cron (free for public repo).",
  "type": "module",
  "private": false,
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:source": "tsx scripts/test-source.ts",
    "run:once": "tsx scripts/run-once.ts",
    "verify": "tsx scripts/verify.ts",
    "verify:opps": "tsx scripts/verify.ts opportunities",
    "verify:phd": "tsx scripts/verify.ts phd_positions",
    "verify:runs": "tsx scripts/verify.ts scraper_runs",
    "backfill:status": "tsx scripts/backfill-status.ts",
    "backfill:euraxess-types": "tsx scripts/backfill-euraxess-types.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.49.1",
    "undici": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
